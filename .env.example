# ─── Database (Supabase Postgres / any Postgres) ───────────────────────────
# Use the Supabase "Connection string" (Session/Transaction pooler is fine for app,
# use the direct connection for the dispatcher worker).
DATABASE_URL=postgresql://postgres:password@localhost:5432/food_erp
# Dispatcher connects with a BYPASSRLS / service role (drains events for all tenants).
# Leave blank in local dev (default superuser bypasses RLS anyway).
DISPATCHER_DATABASE_URL=

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-prod
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── Supabase (Auth + Storage) ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI (OCR + extraction) ─────────────────────────────────────────────────
OPENAI_API_KEY=
# or ANTHROPIC_API_KEY=

# ─── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ─── n8n ───────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ─── Outbox Dispatcher tuning ──────────────────────────────────────────────
DISPATCHER_POLL_INTERVAL_MS=2000
DISPATCHER_BATCH_SIZE=25
DISPATCHER_MAX_RETRIES=5

# ─── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
